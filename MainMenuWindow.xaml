<Window
    x:Class="ste_tool_studio.MainMenuWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="Tools Platform"
    Height="600"
    Width="800"
    MinWidth="600"
    MinHeight="500"
    Background="#1E1E1E"
    WindowStartupLocation="CenterScreen"
    Style="{StaticResource MaterialDesignWindow}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock
            Text="Tools Platform"
            Foreground="White"
            HorizontalAlignment="Center"
            FontSize="32"
            FontWeight="Bold"
            Margin="0,0,0,30" />

        <!-- Tools Grid -->
        <Border
            Grid.Row="1"
            Background="#2D2D30"
            CornerRadius="12"
            Padding="30"
            Margin="0,0,0,20">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Text="Select a Tool"
                    Foreground="LightGray"
                    FontSize="18"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,30" />

                <!-- Tools Container -->
                <UniformGrid
                    Grid.Row="1"
                    Columns="2"
                    Rows="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    
                    <!-- STD Baseline Verifier Tool -->
                    <Button
                        MaxWidth="200"
                        Width="200"
                        x:Name="BaselineVerifierButton"
                        Click="BaselineVerifierButton_Click"
                        Style="{StaticResource GreenButton}"
                        Margin="10"
                        Cursor="Hand"
                        Padding="20"
                        MinHeight="200"
                        RenderTransformOrigin="0.5,0.5">
                        <Button.RenderTransform>
                            <ScaleTransform x:Name="BaselineVerifierScale" ScaleX="1" ScaleY="1"/>
                        </Button.RenderTransform>
                        <Button.Effect>
                            <DropShadowEffect x:Name="BaselineVerifierShadow" 
                                              BlurRadius="0" 
                                              ShadowDepth="0" 
                                              Color="#4CAF50" 
                                              Opacity="0"/>
                        </Button.Effect>
                        <StackPanel>
                            <TextBlock
                                x:Name="BaselineVerifierIcon"
                                Text="🔍"
                                FontSize="48"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,15"
                                RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <ScaleTransform x:Name="BaselineVerifierIconScale" ScaleX="1" ScaleY="1"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock
                                MaxWidth="190"
                                TextAlignment="Center"
                                Text="STD Baseline Verifier"
                                FontSize="20"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"
                                TextWrapping="Wrap"
                                Foreground="White" />
                            <TextBlock
                                TextAlignment="Center"
                                Text="Verify STD bugs and validate rules"
                                FontSize="12"
                                HorizontalAlignment="Center"
                                Foreground="LightGray"
                                Margin="0,10,0,0"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BaselineVerifierScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.08" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="BaselineVerifierScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.08" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="BaselineVerifierShadow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="30" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="BaselineVerifierShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.9" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="BaselineVerifierIconScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.2" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="BaselineVerifierIconScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.2" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BaselineVerifierScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="BaselineVerifierScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="BaselineVerifierShadow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="0" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="BaselineVerifierShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="BaselineVerifierIconScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="BaselineVerifierIconScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                    </Button>

                    <!-- Placeholder for future tools -->
                    <Button
                        MaxWidth="200"
                        Width="200"
                        x:Name="STDTemplateNormalizer"
                        Click="STDTemplateNormalizer_click"
                        Style="{StaticResource PurpleButton}"
                        Margin="10"
                        Cursor="Hand"
                        Padding="20"
                        MinHeight="200"
                        IsEnabled="True"
                        RenderTransformOrigin="0.5,0.5">
                        <Button.RenderTransform>
                            <ScaleTransform x:Name="STDNormalizerScale" ScaleX="1" ScaleY="1"/>
                        </Button.RenderTransform>
                        <Button.Effect>
                            <DropShadowEffect x:Name="STDNormalizerShadow" 
                                              BlurRadius="0" 
                                              ShadowDepth="0" 
                                              Color="#9C27B0" 
                                              Opacity="0"/>
                        </Button.Effect>
                        <StackPanel>
                            <TextBlock
                                x:Name="STDNormalizerIcon"
                                Text="📄"
                                FontSize="48"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,15"
                                RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <ScaleTransform x:Name="STDNormalizerIconScale" ScaleX="1" ScaleY="1"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock
                                MaxWidth="200"
                                Text="STD Template Normalizer"
                                FontSize="20"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"
                                TextWrapping="Wrap"
                                TextAlignment="Center"
                                Foreground="White" />
                            <TextBlock
                                TextAlignment="Center"
                                Text="Normalizes exported STD Word file into template"
                                FontSize="12"
                                HorizontalAlignment="Center"
                                Foreground="LightGray"
                                Margin="0,10,0,0"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="STDNormalizerScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.08" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="STDNormalizerScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.08" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="STDNormalizerShadow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="30" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="STDNormalizerShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.9" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="STDNormalizerIconScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.2" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="STDNormalizerIconScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.2" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="STDNormalizerScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="STDNormalizerScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="STDNormalizerShadow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="0" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="STDNormalizerShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="STDNormalizerIconScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.25"/>
                                        <DoubleAnimation Storyboard.TargetName="STDNormalizerIconScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                    </Button>
                </UniformGrid>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border
            Grid.Row="2"
            Background="#2D2D30"
            Padding="8"
            CornerRadius="8">
            <TextBlock
                Text="Developed by Bahaa"
                Foreground="Gray"
                FontSize="11"
                FontStyle="Italic"
                HorizontalAlignment="Center" />
        </Border>
    </Grid>
</Window>


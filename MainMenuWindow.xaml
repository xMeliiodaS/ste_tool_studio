<Window
    x:Class="ste_tool_studio.MainMenuWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="Tools Platform"
    Width="700"
    Height="600"
    MinWidth="600"
    MinHeight="500"
    Background="#1E1E1E"
    Style="{StaticResource MaterialDesignWindow}"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <TextBlock
            Margin="0,0,0,30"
            HorizontalAlignment="Center"
            FontSize="32"
            FontWeight="Bold"
            Foreground="White"
            Text="Tools Platform" />

        <!--  Tools Grid  -->
        <Border
            Grid.Row="1"
            Margin="0,0,0,20"
            Padding="30"
            Background="#2D2D30"
            CornerRadius="12">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Margin="0,0,0,30"
                    HorizontalAlignment="Center"
                    FontSize="18"
                    Foreground="LightGray"
                    Text="Select a Tool" />

                <!--  Tools Container  -->
                <UniformGrid
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Columns="2"
                    Rows="1">

                    <!--  STD Baseline Verifier Tool  -->
                    <Button
                        x:Name="BaselineVerifierButton"
                        Width="200"
                        MinHeight="200"
                        MaxWidth="200"
                        Margin="10"
                        Padding="20"
                        Click="BaselineVerifierButton_Click"
                        Cursor="Hand"
                        RenderTransformOrigin="0.5,0.5"
                        Style="{StaticResource GreenButton}">
                        <Button.RenderTransform>
                            <ScaleTransform x:Name="BaselineVerifierScale" ScaleX="1" ScaleY="1" />
                        </Button.RenderTransform>
                        <Button.Effect>
                            <DropShadowEffect
                                x:Name="BaselineVerifierShadow"
                                BlurRadius="0"
                                Opacity="0"
                                ShadowDepth="0"
                                Color="#4CAF50" />
                        </Button.Effect>
                        <StackPanel>
                            <TextBlock
                                x:Name="BaselineVerifierIcon"
                                Margin="0,0,0,15"
                                HorizontalAlignment="Center"
                                FontSize="48"
                                RenderTransformOrigin="0.5,0.5"
                                Text="🔍">
                                <TextBlock.RenderTransform>
                                    <ScaleTransform x:Name="BaselineVerifierIconScale" ScaleX="1" ScaleY="1" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock
                                MaxWidth="190"
                                HorizontalAlignment="Center"
                                FontSize="20"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="STD Baseline Verifier"
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                FontSize="12"
                                Foreground="LightGray"
                                Text="Verify STD bugs and validate rules"
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="BaselineVerifierScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1.08"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="BaselineVerifierScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1.08"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="BaselineVerifierShadow"
                                            Storyboard.TargetProperty="BlurRadius"
                                            To="30"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="BaselineVerifierShadow"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.9"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="BaselineVerifierIconScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1.2"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="BaselineVerifierIconScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1.2"
                                            Duration="0:0:0.25" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="BaselineVerifierScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="BaselineVerifierScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="BaselineVerifierShadow"
                                            Storyboard.TargetProperty="BlurRadius"
                                            To="0"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="BaselineVerifierShadow"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="BaselineVerifierIconScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="BaselineVerifierIconScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.25" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                    </Button>

                    <!--  Placeholder for future tools  -->
                    <Button
                        x:Name="STDTemplateNormalizer"
                        Width="200"
                        MinHeight="200"
                        MaxWidth="200"
                        Margin="10"
                        Padding="20"
                        Click="STDTemplateNormalizer_click"
                        Cursor="Hand"
                        IsEnabled="True"
                        RenderTransformOrigin="0.5,0.5"
                        Style="{StaticResource PurpleButton}">
                        <Button.RenderTransform>
                            <ScaleTransform x:Name="STDNormalizerScale" ScaleX="1" ScaleY="1" />
                        </Button.RenderTransform>
                        <Button.Effect>
                            <DropShadowEffect
                                x:Name="STDNormalizerShadow"
                                BlurRadius="0"
                                Opacity="0"
                                ShadowDepth="0"
                                Color="#9C27B0" />
                        </Button.Effect>
                        <StackPanel>
                            <TextBlock
                                x:Name="STDNormalizerIcon"
                                Margin="0,0,0,15"
                                HorizontalAlignment="Center"
                                FontSize="48"
                                RenderTransformOrigin="0.5,0.5"
                                Text="📄">
                                <TextBlock.RenderTransform>
                                    <ScaleTransform x:Name="STDNormalizerIconScale" ScaleX="1" ScaleY="1" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock
                                MaxWidth="200"
                                HorizontalAlignment="Center"
                                FontSize="20"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="STD Template Normalizer"
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                FontSize="12"
                                Foreground="LightGray"
                                Text="Normalizes exported STD Word file into template"
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="STDNormalizerScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1.08"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="STDNormalizerScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1.08"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="STDNormalizerShadow"
                                            Storyboard.TargetProperty="BlurRadius"
                                            To="30"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="STDNormalizerShadow"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.9"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="STDNormalizerIconScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1.2"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="STDNormalizerIconScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1.2"
                                            Duration="0:0:0.25" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="STDNormalizerScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="STDNormalizerScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="STDNormalizerShadow"
                                            Storyboard.TargetProperty="BlurRadius"
                                            To="0"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="STDNormalizerShadow"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="STDNormalizerIconScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="STDNormalizerIconScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.25" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                    </Button>
                </UniformGrid>
            </Grid>
        </Border>

        <!--  Footer  -->
        <Border
            Grid.Row="2"
            Padding="8"
            Background="#2D2D30"
            CornerRadius="8">
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="11"
                FontStyle="Italic"
                Foreground="Gray"
                Text="Developed by Bahaa" />
        </Border>
    </Grid>
</Window>


<local:BaseToolWindow
    x:Class="ste_tool_studio.BaselineVerifierWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:ste_tool_studio"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="STD Baseline Verifier"
    Width="690"
    Height="580"
    MinWidth="690"
    MinHeight="575"
    AllowDrop="True"
    Background="#1E1E1E"
    DragOver="Window_DragOver"
    Drop="Window_Drop"
    Style="{StaticResource MaterialDesignWindow}"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="20,20,20,5">

        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="1.15" ScaleY="1.15" />
        </Grid.LayoutTransform>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header with Back Button  -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="BackButton"
                Grid.Column="0"
                MinWidth="40"
                Margin="0,0,15,0"
                Background="#3C3C3C"
                BorderBrush="#555"
                Click="BackButton_Click"
                Cursor="Hand"
                Foreground="White"
                RenderTransformOrigin="0.5,0.5"
                Style="{StaticResource CustomMaterialButton}">
                <Button.RenderTransform>
                    <ScaleTransform x:Name="BackButtonScaleBV" ScaleX="1" ScaleY="1" />
                </Button.RenderTransform>
                <Button.Effect>
                    <DropShadowEffect
                        x:Name="BackButtonShadowBV"
                        BlurRadius="0"
                        Opacity="0"
                        ShadowDepth="0"
                        Color="#FFFFFF" />
                </Button.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,5,0"
                        VerticalAlignment="Center"
                        FontSize="18"
                        Text="&lt;" />
                </StackPanel>
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource CustomToolTip}">
                        Return to Main Menu
                    </ToolTip>
                </Button.ToolTip>
                <Button.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetName="BackButtonScaleBV"
                                    Storyboard.TargetProperty="ScaleX"
                                    To="1.1"
                                    Duration="0:0:0.2" />
                                <DoubleAnimation
                                    Storyboard.TargetName="BackButtonScaleBV"
                                    Storyboard.TargetProperty="ScaleY"
                                    To="1.1"
                                    Duration="0:0:0.2" />
                                <DoubleAnimation
                                    Storyboard.TargetName="BackButtonShadowBV"
                                    Storyboard.TargetProperty="BlurRadius"
                                    To="10"
                                    Duration="0:0:0.2" />
                                <DoubleAnimation
                                    Storyboard.TargetName="BackButtonShadowBV"
                                    Storyboard.TargetProperty="Opacity"
                                    To="0.6"
                                    Duration="0:0:0.2" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetName="BackButtonScaleBV"
                                    Storyboard.TargetProperty="ScaleX"
                                    To="1"
                                    Duration="0:0:0.2" />
                                <DoubleAnimation
                                    Storyboard.TargetName="BackButtonScaleBV"
                                    Storyboard.TargetProperty="ScaleY"
                                    To="1"
                                    Duration="0:0:0.2" />
                                <DoubleAnimation
                                    Storyboard.TargetName="BackButtonShadowBV"
                                    Storyboard.TargetProperty="BlurRadius"
                                    To="0"
                                    Duration="0:0:0.2" />
                                <DoubleAnimation
                                    Storyboard.TargetName="BackButtonShadowBV"
                                    Storyboard.TargetProperty="Opacity"
                                    To="0"
                                    Duration="0:0:0.2" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
            </Button>

            <!--  Title  -->
            <TextBlock
                Grid.Column="0"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="26"
                FontWeight="Bold"
                Foreground="White"
                Text="STD Baseline Verifier" />
        </Grid>


        <!--  Main Content  -->
        <Border
            Grid.Row="1"
            Grid.RowSpan="2"
            Margin="0,0,0,59"
            Padding="20"
            Background="#2D2D30"
            CornerRadius="12">

            <StackPanel>

                <!--  File Selector Button  -->
                <Button
                    x:Name="SelectSTDButton"
                    Margin="0,0,0,4"
                    Click="SelectSTDButton_Click"
                    Cursor="Hand"
                    RenderTransformOrigin="0.5,0.5"
                    Style="{StaticResource PurpleButton}">
                    <Button.RenderTransform>
                        <ScaleTransform x:Name="SelectSTDScale" ScaleX="1" ScaleY="1" />
                    </Button.RenderTransform>
                    <Button.Effect>
                        <DropShadowEffect
                            x:Name="SelectSTDShadow"
                            BlurRadius="0"
                            Opacity="0"
                            ShadowDepth="0"
                            Color="#9C27B0" />
                    </Button.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Name="SelectSTDIcon"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            FontSize="18"
                            RenderTransformOrigin="0.5,0.5"
                            Text="📂">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="SelectSTDIconRotate" Angle="0" />
                            </TextBlock.RenderTransform>
                        </TextBlock>

                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Text="Select STD (Excel)"
                            TextWrapping="Wrap" />
                    </Grid>
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectSTDScale"
                                        Storyboard.TargetProperty="ScaleX"
                                        To="1.05"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectSTDScale"
                                        Storyboard.TargetProperty="ScaleY"
                                        To="1.05"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectSTDShadow"
                                        Storyboard.TargetProperty="BlurRadius"
                                        To="20"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectSTDShadow"
                                        Storyboard.TargetProperty="Opacity"
                                        To="0.7"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectSTDIconRotate"
                                        Storyboard.TargetProperty="Angle"
                                        To="15"
                                        Duration="0:0:0.2" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectSTDScale"
                                        Storyboard.TargetProperty="ScaleX"
                                        To="1"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectSTDScale"
                                        Storyboard.TargetProperty="ScaleY"
                                        To="1"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectSTDShadow"
                                        Storyboard.TargetProperty="BlurRadius"
                                        To="0"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectSTDShadow"
                                        Storyboard.TargetProperty="Opacity"
                                        To="0"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectSTDIconRotate"
                                        Storyboard.TargetProperty="Angle"
                                        To="0"
                                        Duration="0:0:0.2" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <!--  Drag & Drop Hint  -->
                <TextBlock
                    Margin="0,0,0,10"
                    HorizontalAlignment="Center"
                    FontSize="12"
                    FontStyle="Italic"
                    Foreground="LightGray"
                    Text="Or drag and drop an Excel file here" />

                <!--  Selected File Label  -->
                <TextBlock
                    x:Name="SelectedFileLabel"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    Foreground="LightGray"
                    Text="{Binding SelectedFileName}"
                    TextWrapping="Wrap" />
                <!--  STD Name with Placeholder  -->
                <Grid Width="325" Margin="0,3,0,7">

                    <TextBox
                        x:Name="STDNameInput"
                        Height="36.62"
                        Padding="8"
                        HorizontalContentAlignment="Center"
                        Background="#3C3C3C"
                        BorderBrush="#555"
                        FontSize="14"
                        Foreground="White"
                        Text="{Binding StdName, UpdateSourceTrigger=PropertyChanged}"
                        TextChanged="STDNameInput_TextChanged" />

                    <TextBlock
                        x:Name="STDPlaceholder"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="15"
                        Foreground="Gray"
                        IsHitTestVisible="False"
                        Text="STD Name" />
                </Grid>


                <!--  Iteration Path + Current V&V Version  -->
                <Grid Width="325" Margin="0,3,0,28">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="190" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="126" />
                    </Grid.ColumnDefinitions>


                    <!--  Iteration Path  -->
                    <Grid Grid.Column="0">

                        <TextBox
                            x:Name="IterationPathInput"
                            Height="36.62"
                            Padding="8"
                            HorizontalContentAlignment="Center"
                            Background="#3C3C3C"
                            BorderBrush="#555"
                            FontSize="14"
                            Foreground="White"
                            Text="{Binding IterationPath, UpdateSourceTrigger=PropertyChanged}"
                            TextChanged="IterationPathInput_TextChanged" />

                        <TextBlock
                            x:Name="IterationPathPlaceholder"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="15"
                            Foreground="Gray"
                            IsHitTestVisible="False"
                            Text="Iteration Path" />
                    </Grid>


                    <!--  Current V&V Version  -->
                    <Grid Grid.Column="2">

                        <TextBox
                            x:Name="VVVersionInput"
                            Height="36.62"
                            Padding="8"
                            HorizontalContentAlignment="Center"
                            Background="#3C3C3C"
                            BorderBrush="#555"
                            FontSize="14"
                            Foreground="White"
                            Text="{Binding VvVersion, UpdateSourceTrigger=PropertyChanged}"
                            TextChanged="VVVersionInput_TextChanged" />

                        <TextBlock
                            x:Name="VVVersionPlaceholder"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="15"
                            Foreground="Gray"
                            IsHitTestVisible="False"
                            Text="V&amp;V Version" />
                    </Grid>

                </Grid>



                <!--  ACTION BUTTONS  -->
                <Grid Margin="0,-5,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Run Bug Verification Button  -->
                    <Button
                        x:Name="RunAutomationButton"
                        Grid.Row="0"
                        Height="40"
                        MaxWidth="350"
                        Margin="0,0,0,6"
                        Click="RunAutomationButton_Click"
                        Cursor="Hand"
                        RenderTransformOrigin="0.5,0.5"
                        Style="{StaticResource GreenButton}"
                        ToolTipService.BetweenShowDelay="0"
                        ToolTipService.InitialShowDelay="500">
                        <Button.RenderTransform>
                            <ScaleTransform x:Name="RunAutomationScale" ScaleX="1" ScaleY="1" />
                        </Button.RenderTransform>
                        <Button.Effect>
                            <DropShadowEffect
                                x:Name="RunAutomationShadow"
                                BlurRadius="0"
                                Opacity="0"
                                ShadowDepth="0"
                                Color="#4CAF50" />
                        </Button.Effect>
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource CustomToolTip}">
                                <TextBlock TextWrapping="Wrap">
                                    Runs full verification:<LineBreak />
                                    • Extracts Failed Test Case IDs and Bugs from Excel<LineBreak />
                                    • Checks each Bug in VSTS for correct STD ID, Iteration Path, and Last Reproduce In<LineBreak />
                                    • Generates a summary Report of all findings</TextBlock>
                            </ToolTip>
                        </Button.ToolTip>



                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                x:Name="RunIcon"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                FontSize="18"
                                Text="▶" />

                            <TextBlock
                                x:Name="RunButtonText"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Text="Check STD Bugs in VSTS"
                                TextWrapping="Wrap" />

                            <Ellipse
                                x:Name="ButtonSpinner"
                                Width="16"
                                Height="16"
                                Margin="0,0,8,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Stroke="White"
                                StrokeDashArray="2,2"
                                StrokeThickness="2"
                                Visibility="Collapsed">
                                <Ellipse.RenderTransform>
                                    <RotateTransform x:Name="ButtonSpinnerRotate" CenterX="8" CenterY="8" />
                                </Ellipse.RenderTransform>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                        <BeginStoryboard x:Name="ButtonSpinnerStoryboard">
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation
                                                    Storyboard.TargetName="ButtonSpinnerRotate"
                                                    Storyboard.TargetProperty="Angle"
                                                    From="0"
                                                    To="360"
                                                    Duration="0:0:1" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                        </Grid>
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="RunAutomationScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1.06"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="RunAutomationScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1.06"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="RunAutomationShadow"
                                            Storyboard.TargetProperty="BlurRadius"
                                            To="25"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="RunAutomationShadow"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.8"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="RunAutomationScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="RunAutomationScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="RunAutomationShadow"
                                            Storyboard.TargetProperty="BlurRadius"
                                            To="0"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="RunAutomationShadow"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                    </Button>


                    <!--  Open Last Report button  -->
                    <Button
                        x:Name="OpenLastBugsReportButton"
                        Grid.Column="1"
                        Width="32"
                        Height="40"
                        Margin="317,0,0,6"
                        VerticalAlignment="Center"
                        Click="OpenLastBugsReportButton_Click"
                        Content="📑"
                        Cursor="Hand"
                        FontSize="16"
                        RenderTransformOrigin="0.5,0.5"
                        Style="{StaticResource BugReportButton}"
                        ToolTipService.BetweenShowDelay="0"
                        ToolTipService.InitialShowDelay="0">
                        <Button.RenderTransform>
                            <ScaleTransform x:Name="OpenBugsReportScale" ScaleX="1" ScaleY="1" />
                        </Button.RenderTransform>
                        <Button.Effect>
                            <DropShadowEffect
                                x:Name="OpenBugsReportShadow"
                                BlurRadius="0"
                                Opacity="0"
                                ShadowDepth="0"
                                Color="#4CAF50" />
                        </Button.Effect>

                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource CustomToolTip}">
                                Open Last Report
                            </ToolTip>
                        </Button.ToolTip>
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="OpenBugsReportScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1.15"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="OpenBugsReportScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1.15"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="OpenBugsReportShadow"
                                            Storyboard.TargetProperty="BlurRadius"
                                            To="15"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="OpenBugsReportShadow"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.7"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="OpenBugsReportScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="OpenBugsReportScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="OpenBugsReportShadow"
                                            Storyboard.TargetProperty="BlurRadius"
                                            To="0"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="OpenBugsReportShadow"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                    </Button>


                    <!--  Check Excel Violations  -->
                    <Button
                        x:Name="RunViolationButton"
                        Grid.Row="1"
                        Height="40"
                        Margin="0,10,0,0"
                        Click="RunViolationButton_Click"
                        Cursor="Hand"
                        RenderTransformOrigin="0.5,0.5"
                        Style="{StaticResource BlueButton}">
                        <Button.RenderTransform>
                            <ScaleTransform x:Name="RunViolationScale" ScaleX="1" ScaleY="1" />
                        </Button.RenderTransform>
                        <Button.Effect>
                            <DropShadowEffect
                                x:Name="RunViolationShadow"
                                BlurRadius="0"
                                Opacity="0"
                                ShadowDepth="0"
                                Color="#0D47A1" />
                        </Button.Effect>

                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource CustomToolTip}">
                                <TextBlock TextWrapping="Wrap">
                                    Validates the STD Excel file and VSTS data:<LineBreak />
                                    • Checks that every Expected Result has a corresponding Test Result<LineBreak />
                                    • Verifies that any passed Test Result does not incorrectly have a Bug number<LineBreak />
                                    • Confirms that failed Test Results have an associated Bug number<LineBreak />
                                    • Generates a comprehensive HTML report summarizing all findings</TextBlock>
                            </ToolTip>
                        </Button.ToolTip>



                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                x:Name="ViolationIcon"
                                VerticalAlignment="Center"
                                FontSize="15"
                                Text="" />

                            <TextBlock
                                x:Name="RunViolationButtonText"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Text="Validate STD Rules"
                                TextWrapping="Wrap" />

                            <Ellipse
                                x:Name="ViolationButtonSpinner"
                                Width="16"
                                Height="16"
                                Margin="0,0,8,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Stroke="White"
                                StrokeDashArray="2,2"
                                StrokeThickness="2"
                                Visibility="Collapsed">
                                <Ellipse.RenderTransform>
                                    <RotateTransform x:Name="ViolationButtonSpinnerRotate" CenterX="8" CenterY="8" />
                                </Ellipse.RenderTransform>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                        <BeginStoryboard x:Name="ViolationSpinnerStoryboard">
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation
                                                    Storyboard.TargetName="ViolationButtonSpinnerRotate"
                                                    Storyboard.TargetProperty="Angle"
                                                    From="0"
                                                    To="360"
                                                    Duration="0:0:1" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                        </Grid>
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="RunViolationScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1.06"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="RunViolationScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1.06"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="RunViolationShadow"
                                            Storyboard.TargetProperty="BlurRadius"
                                            To="25"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="RunViolationShadow"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.8"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="RunViolationScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="RunViolationScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="RunViolationShadow"
                                            Storyboard.TargetProperty="BlurRadius"
                                            To="0"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="RunViolationShadow"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                    </Button>

                </Grid>

                <!--  Open Last Report button  -->
                <Button
                    x:Name="OpenLastRulesReportButton"
                    Grid.Column="1"
                    Width="32"
                    Height="40"
                    Margin="197,-40,0,0"
                    VerticalAlignment="Center"
                    Click="OpenLastRulesReportButton_Click"
                    Content="📑"
                    Cursor="Hand"
                    FontSize="16"
                    RenderTransformOrigin="0.5,0.5"
                    Style="{StaticResource RulesReportButton}"
                    ToolTipService.BetweenShowDelay="0"
                    ToolTipService.InitialShowDelay="0">
                    <Button.RenderTransform>
                        <ScaleTransform x:Name="OpenRulesReportScale" ScaleX="1" ScaleY="1" />
                    </Button.RenderTransform>
                    <Button.Effect>
                        <DropShadowEffect
                            x:Name="OpenRulesReportShadow"
                            BlurRadius="0"
                            Opacity="0"
                            ShadowDepth="0"
                            Color="#0D47A1" />
                    </Button.Effect>

                    <Button.ToolTip>
                        <ToolTip Style="{StaticResource CustomToolTip}">
                            Open Last Report
                        </ToolTip>
                    </Button.ToolTip>
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetName="OpenRulesReportScale"
                                        Storyboard.TargetProperty="ScaleX"
                                        To="1.15"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="OpenRulesReportScale"
                                        Storyboard.TargetProperty="ScaleY"
                                        To="1.15"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="OpenRulesReportShadow"
                                        Storyboard.TargetProperty="BlurRadius"
                                        To="15"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="OpenRulesReportShadow"
                                        Storyboard.TargetProperty="Opacity"
                                        To="0.7"
                                        Duration="0:0:0.2" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetName="OpenRulesReportScale"
                                        Storyboard.TargetProperty="ScaleX"
                                        To="1"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="OpenRulesReportScale"
                                        Storyboard.TargetProperty="ScaleY"
                                        To="1"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="OpenRulesReportShadow"
                                        Storyboard.TargetProperty="BlurRadius"
                                        To="0"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="OpenRulesReportShadow"
                                        Storyboard.TargetProperty="Opacity"
                                        To="0"
                                        Duration="0:0:0.2" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

            </StackPanel>
        </Border>

        <!--  Status Bar  -->
        <Border
            Grid.Row="2"
            Margin="0,1,0,0"
            Padding="8"
            Background="#2D2D30"
            CornerRadius="8">

            <StackPanel HorizontalAlignment="Center">
                <TextBlock
                    x:Name="StatusText"
                    HorizontalAlignment="Center"
                    FontSize="12"
                    Foreground="LightGray"
                    Text="{Binding StatusMessage}" />
                <TextBlock
                    Margin="0,4,0,0"
                    HorizontalAlignment="Center"
                    FontSize="11"
                    FontStyle="Italic"
                    Foreground="Gray"
                    Text="Developed by Bahaa" />
            </StackPanel>
        </Border>

    </Grid>
</local:BaseToolWindow>


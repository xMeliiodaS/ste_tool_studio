<Window
    x:Class="ste_tool_studio.STDTemplateNormalizer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="STD Template Normalizer"
    Height="620"
    Width="700"
    MinWidth="700"
    MinHeight="620"
    Background="#1E1E1E"
    WindowStartupLocation="CenterScreen"
    Style="{StaticResource MaterialDesignWindow}"
    AllowDrop="True"
    Drop="Window_Drop"
    DragOver="Window_DragOver">

    <Grid
        Margin="20,20,20,5">

        <Grid.LayoutTransform>
            <ScaleTransform
                ScaleX="1.15"
                ScaleY="1.15" />
        </Grid.LayoutTransform>

        <Grid.RowDefinitions>
            <RowDefinition
                Height="Auto" />
            <RowDefinition
                Height="*" />
            <RowDefinition
                Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header with Back Button -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Back Button -->
            <Button
                x:Name="BackButton"
                Grid.Column="0"
                Click="BackButton_Click"
                Style="{StaticResource CustomMaterialButton}"
                Background="#3C3C3C"
                Foreground="White"
                BorderBrush="#555"
                Margin="0,0,15,0"
                MinWidth="40"
                Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Text="&lt;"
                        FontSize="18"
                        Margin="0,0,5,0"
                        VerticalAlignment="Center" />
                </StackPanel>
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource CustomToolTip}">
                        Return to Main Menu
                    </ToolTip>
                </Button.ToolTip>
            </Button>

            <!-- Title -->
            <TextBlock
                Grid.Column="0"
                Grid.ColumnSpan="2"                
                Text="STD Template Normalizer"
                Foreground="White"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="26"
                FontWeight="Bold" />
        </Grid>


        <!-- Main Content -->
        <Border
            Grid.Row="1"
            Background="#2D2D30"
            CornerRadius="12"
            Padding="20"
            Margin="0,0,0,59"
            Grid.RowSpan="2">

            <StackPanel>

                <!-- File Selector Button -->
                <Button
                    x:Name="SelectFileButton"
                    Click="SelectFileButton_Click"
                    Style="{StaticResource PurpleButton}"
                    Margin="0,0,0,4"
                    Cursor="Hand">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="Auto" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Text="📂"
                            FontSize="18"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center" />

                        <TextBlock
                            Grid.Column="1"
                            Text="Select DOCX File"
                            TextWrapping="Wrap"
                            VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <!-- Drag & Drop Hint -->
                <TextBlock
                    Text="Or drag and drop a DOCX file here"
                    Foreground="LightGray"
                    FontStyle="Italic"
                    FontSize="12"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,5" />

                <!-- Selected File Label -->
                <TextBlock
                    x:Name="SelectedFileLabel"
                    HorizontalAlignment="Center"
                    Text="No file selected"
                    Foreground="LightGray"
                    FontSize="14"
                    TextWrapping="Wrap"
                    Margin="0,10,0,20" />

                <!-- Input Fields -->
                <StackPanel
                    Margin="0,0,0,20"
                    HorizontalAlignment="Center">
                    
                    <!-- Row 1: STD Name (Full Width) -->
                    <Grid Margin="0,0,0,10" HorizontalAlignment="Center">
                        <TextBox
                            x:Name="STDNameInput"
                            Width="314"
                            Background="#3C3C3C"
                            Foreground="White"
                            BorderBrush="#555"
                            Padding="10,8"
                            FontSize="14"
                            BorderThickness="1"
                            HorizontalContentAlignment="Center"
                            TextChanged="STDNameInput_TextChanged" />
                        <TextBlock
                            x:Name="STDNamePlaceholder"
                            Text="STD Name"
                            Foreground="Gray"
                            FontSize="14"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False" />
                    </Grid>

                    <!-- Row 2: DOC # and Plan (Side by Side) -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- DOC # Input (Left) -->
                        <Grid Grid.Column="0" Margin="0,0,7,0">
                            <TextBox
                                x:Name="DOCNumberInput"
                                Width="200"
                                Background="#3C3C3C"
                                Foreground="White"
                                BorderBrush="#555"
                                Padding="10,8"
                                FontSize="14"
                                BorderThickness="1"
                                HorizontalContentAlignment="Center"
                                TextChanged="DOCNumberInput_TextChanged" />
                            <TextBlock
                                x:Name="DOCNumberPlaceholder"
                                Text="DOC number"
                                Foreground="Gray"
                                FontSize="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False" />
                        </Grid>

                        <!-- Plan Input (Right) -->
                        <Grid Grid.Column="1" Margin="7,0,0,0">
                            <TextBox
                                x:Name="ProjectInput"
                                Width="100"
                                Background="#3C3C3C"
                                Foreground="White"
                                BorderBrush="#555"
                                Padding="10,8"
                                FontSize="14"
                                BorderThickness="1"
                                HorizontalContentAlignment="Center"
                                TextChanged="PlanInput_TextChanged" />
                            <TextBlock
                                x:Name="ProjectPlaceholder"
                                Text="Project number"
                                Foreground="Gray"
                                FontSize="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False" />
                        </Grid>
                    </Grid>

                    <!-- Row 3: Test plan and Prepared by (Side by Side) -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Test plan Input (Left) -->
                        <Grid Grid.Column="0" Margin="0,0,7,0">
                            <TextBox
                                x:Name="TestPlanInput"
                                Width="150"
                                Background="#3C3C3C"
                                Foreground="White"
                                BorderBrush="#555"
                                Padding="10,8"
                                FontSize="14"
                                BorderThickness="1"
                                HorizontalContentAlignment="Center"
                                TextChanged="TestPlanInput_TextChanged" />
                            <TextBlock
                                x:Name="TestPlanPlaceholder"
                                Text="Test plan"
                                Foreground="Gray"
                                FontSize="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False" />
                        </Grid>

                        <!-- Prepared by Input (Right) -->
                        <Grid Grid.Column="1" Margin="7,0,0,0">
                            <TextBox
                                x:Name="PreparedByInput"
                                Width="150"
                                Background="#3C3C3C"
                                Foreground="White"
                                BorderBrush="#555"
                                Padding="10,8"
                                FontSize="14"
                                BorderThickness="1"
                                HorizontalContentAlignment="Center"
                                TextChanged="PreparedByInput_TextChanged" />
                            <TextBlock
                                x:Name="PreparedByPlaceholder"
                                Text="Prepared by"
                                Foreground="Gray"
                                FontSize="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False" />
                        </Grid>
                    </Grid>

                    <!-- Row 4: Footer (Centered) -->
                    <Grid Margin="0,0,0,0" HorizontalAlignment="Center">
                        <TextBox
                            x:Name="FooterInput"
                            Width="150"
                            Background="#3C3C3C"
                            Foreground="White"
                            BorderBrush="#555"
                            Padding="10,8"
                            FontSize="14"
                            BorderThickness="1"
                            HorizontalContentAlignment="Center"
                            TextChanged="FooterInput_TextChanged" />
                        <TextBlock
                            x:Name="FooterPlaceholder"
                            Text="Footer"
                            Foreground="Gray"
                            FontSize="14"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False" />
                    </Grid>
                    
                </StackPanel>

                <!-- Generate Button -->
                <Button
                    x:Name="GenerateButton"
                    Click="GenerateButton_Click"
                    Style="{StaticResource GreenButton}"
                    MaxWidth="350"
                    Cursor="Hand"
                    Height="40"
                    Margin="0,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="Auto" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Text="⚙"
                            FontSize="18"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center" />

                        <TextBlock
                            Grid.Column="1"
                            Text="Generate"
                            TextWrapping="Wrap"
                            VerticalAlignment="Center" />
                    </Grid>
                </Button>

            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border
            Grid.Row="2"
            Background="#2D2D30"
            Padding="8"
            CornerRadius="8"
            Margin="0,1,0,0">

            <StackPanel
                HorizontalAlignment="Center">
                <TextBlock
                    x:Name="StatusText"
                    Text="Ready"
                    Foreground="LightGray"
                    FontSize="12"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="Developed by Bahaa"
                    Foreground="Gray"
                    FontSize="11"
                    FontStyle="Italic"
                    Margin="0,4,0,0"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

    </Grid>
</Window>

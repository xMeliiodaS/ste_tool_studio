<local:BaseToolWindow
    x:Class="ste_tool_studio.STDTemplateNormalizer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:local="clr-namespace:ste_tool_studio"
    Title="STD Template Normalizer"
    Height="710"
    Width="700"
    MinWidth="700"
    MinHeight="710"
    Background="#1E1E1E"
    WindowStartupLocation="CenterScreen"
    Style="{StaticResource MaterialDesignWindow}"
    AllowDrop="True"
    Drop="Window_Drop"
    DragOver="Window_DragOver">

    <Grid
        Margin="20,20,20,5">

        <Grid.LayoutTransform>
            <ScaleTransform
                ScaleX="1.15"
                ScaleY="1.15" />
        </Grid.LayoutTransform>

        <Grid.RowDefinitions>
            <RowDefinition
                Height="Auto" />
            <RowDefinition
                Height="*" />
            <RowDefinition
                Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header with Back Button -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Back Button -->
            <Button
                x:Name="BackButton"
                Grid.Column="0"
                Click="BackButton_Click"
                Style="{StaticResource CustomMaterialButton}"
                Background="#3C3C3C"
                Foreground="White"
                BorderBrush="#555"
                Margin="0,0,15,0"
                MinWidth="40"
                Cursor="Hand"
                RenderTransformOrigin="0.5,0.5">
                <Button.RenderTransform>
                    <ScaleTransform x:Name="BackButtonScale" ScaleX="1" ScaleY="1"/>
                </Button.RenderTransform>
                <Button.Effect>
                    <DropShadowEffect x:Name="BackButtonShadow" 
                                      BlurRadius="0" 
                                      ShadowDepth="0" 
                                      Color="#FFFFFF" 
                                      Opacity="0"/>
                </Button.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Text="&lt;"
                        FontSize="18"
                        Margin="0,0,5,0"
                        VerticalAlignment="Center" />
                </StackPanel>
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource CustomToolTip}">
                        Return to Main Menu
                    </ToolTip>
                </Button.ToolTip>
                <Button.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="BackButtonScale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="1.1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetName="BackButtonScale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="1.1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetName="BackButtonShadow"
                                                 Storyboard.TargetProperty="BlurRadius"
                                                 To="10" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetName="BackButtonShadow"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0.6" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="BackButtonScale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetName="BackButtonScale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetName="BackButtonShadow"
                                                 Storyboard.TargetProperty="BlurRadius"
                                                 To="0" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetName="BackButtonShadow"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
            </Button>

            <!-- Title -->
            <TextBlock
                Grid.Column="0"
                Grid.ColumnSpan="2"                
                Text="STD Template Normalizer"
                Foreground="White"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="26"
                FontWeight="Bold" />
        </Grid>


        <!-- Main Content -->
        <Border
            Grid.Row="1"
            Background="#2D2D30"
            CornerRadius="12"
            Padding="20"
            Margin="0,0,0,59"
            Grid.RowSpan="2">

            <StackPanel>

                <!-- File Selector Button -->
                <Button
                    x:Name="SelectFileButton"
                    Click="SelectFileButton_Click"
                    Style="{StaticResource PurpleButton}"
                    Margin="0,0,0,4"
                    Cursor="Hand"
                    RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <ScaleTransform x:Name="SelectFileScale" ScaleX="1" ScaleY="1"/>
                    </Button.RenderTransform>
                    <Button.Effect>
                        <DropShadowEffect x:Name="SelectFileShadow" 
                                          BlurRadius="0" 
                                          ShadowDepth="0" 
                                          Color="#9C27B0" 
                                          Opacity="0"/>
                    </Button.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="Auto" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Name="SelectFileIcon"
                            Text="📂"
                            FontSize="18"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="SelectFileIconRotate" Angle="0"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>

                        <TextBlock
                            Grid.Column="1"
                            Text="Select STD File"
                            TextWrapping="Wrap"
                            VerticalAlignment="Center" />
                    </Grid>
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="SelectFileScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1.05" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="SelectFileScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1.05" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="SelectFileShadow"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     To="20" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="SelectFileShadow"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.7" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="SelectFileIconRotate"
                                                     Storyboard.TargetProperty="Angle"
                                                     To="15" Duration="0:0:0.2"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="SelectFileScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="SelectFileScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="SelectFileShadow"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     To="0" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="SelectFileShadow"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="SelectFileIconRotate"
                                                     Storyboard.TargetProperty="Angle"
                                                     To="0" Duration="0:0:0.2"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Drag & Drop Hint -->
                <TextBlock
                    Text="Or drag and drop a DOCX file here"
                    Foreground="LightGray"
                    FontStyle="Italic"
                    FontSize="12"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,5" />

                <!-- Selected File Label -->
                <TextBlock
                    x:Name="SelectedFileLabel"
                    HorizontalAlignment="Center"
                    Text="{Binding SelectedFileName}"
                    Foreground="LightGray"
                    FontSize="14"
                    TextWrapping="Wrap"
                    Margin="0,10,0,15" />

                <!-- Document Type Card -->
                <Border
    Background="#1E1E1E"
    CornerRadius="20"
    Padding="1"
    BorderThickness="1"
    BorderBrush="#555"
    HorizontalAlignment="Center"
    Margin="0,0,0,15">

                    <StackPanel>

                        <!-- Title -->
                        <TextBlock
            Text="Document Type"
            Foreground="LightGray"
            FontSize="13"
            FontWeight="SemiBold"
                            HorizontalAlignment="Center"
            Margin="6,2,0,5" />

                        <!-- Toggle Container -->
                        <Border
            Background="#111"
            CornerRadius="16"
            Padding="3">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>

                                <!-- Protocol -->
                                <Button
                    x:Name="ProtocolButton"
                    Grid.Column="0"
                    Content="Protocol"
                    Padding="18,8"
                    FontSize="13"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="ProtocolButton_Click"
                    Background="#1E1E1E"
                    Foreground="LightGray"
                    MinWidth="90"
                    RenderTransformOrigin="0.5,0.5">

                                    <Button.RenderTransform>
                                        <ScaleTransform x:Name="ProtocolScale" ScaleX="1" ScaleY="1"/>
                                    </Button.RenderTransform>
                                    <Button.Effect>
                                        <DropShadowEffect x:Name="ProtocolShadow" 
                                                          BlurRadius="0" 
                                                          ShadowDepth="0" 
                                                          Color="#4CAF50" 
                                                          Opacity="0"/>
                                    </Button.Effect>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border
                                Background="{TemplateBinding Background}"
                                CornerRadius="16">
                                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Triggers>
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ProtocolScale"
                                                                     Storyboard.TargetProperty="ScaleX"
                                                                     To="1.08" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="ProtocolScale"
                                                                     Storyboard.TargetProperty="ScaleY"
                                                                     To="1.08" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="ProtocolShadow"
                                                                     Storyboard.TargetProperty="BlurRadius"
                                                                     To="12" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="ProtocolShadow"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="0.5" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ProtocolScale"
                                                                     Storyboard.TargetProperty="ScaleX"
                                                                     To="1" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="ProtocolScale"
                                                                     Storyboard.TargetProperty="ScaleY"
                                                                     To="1" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="ProtocolShadow"
                                                                     Storyboard.TargetProperty="BlurRadius"
                                                                     To="0" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="ProtocolShadow"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="0" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Button.Triggers>

                                </Button>

                                <!-- Report -->
                                <Button
                    x:Name="ReportButton"
                    Grid.Column="1"
                    Content="Report"
                    Padding="18,8"
                    FontSize="13"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="ReportButton_Click"
                    Background="#1E1E1E"
                    Foreground="LightGray"
                    MinWidth="90"
                    RenderTransformOrigin="0.5,0.5">

                                    <Button.RenderTransform>
                                        <ScaleTransform x:Name="ReportScale" ScaleX="1" ScaleY="1"/>
                                    </Button.RenderTransform>
                                    <Button.Effect>
                                        <DropShadowEffect x:Name="ReportShadow" 
                                                          BlurRadius="0" 
                                                          ShadowDepth="0" 
                                                          Color="#4CAF50" 
                                                          Opacity="0"/>
                                    </Button.Effect>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border
                                Background="{TemplateBinding Background}"
                                CornerRadius="16">
                                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Triggers>
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ReportScale"
                                                                     Storyboard.TargetProperty="ScaleX"
                                                                     To="1.08" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="ReportScale"
                                                                     Storyboard.TargetProperty="ScaleY"
                                                                     To="1.08" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="ReportShadow"
                                                                     Storyboard.TargetProperty="BlurRadius"
                                                                     To="12" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="ReportShadow"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="0.5" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ReportScale"
                                                                     Storyboard.TargetProperty="ScaleX"
                                                                     To="1" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="ReportScale"
                                                                     Storyboard.TargetProperty="ScaleY"
                                                                     To="1" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="ReportShadow"
                                                                     Storyboard.TargetProperty="BlurRadius"
                                                                     To="0" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="ReportShadow"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="0" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Button.Triggers>

                                </Button>

                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- Input Fields -->
                <StackPanel
                    Margin="0,0,0,15"
                    HorizontalAlignment="Center">
                    
                    <!-- Row 1: STD Name (Full Width) -->
                    <Grid Margin="0,0,0,10" HorizontalAlignment="Center">
                        <TextBox
                            x:Name="STDNameInput"
                            Width="314"
                            Background="#3C3C3C"
                            Foreground="White"
                            BorderBrush="#555"
                            Padding="10,8"
                            FontSize="14"
                            BorderThickness="1"
                            HorizontalContentAlignment="Center"
                            Text="{Binding StdName, UpdateSourceTrigger=PropertyChanged}"
                            TextChanged="STDNameInput_TextChanged" />
                        <TextBlock
                            x:Name="STDNamePlaceholder"
                            Text="STD Name"
                            Foreground="Gray"
                            FontSize="14"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False" />
                    </Grid>

                    <!-- Row 2: DOC # and Plan (Side by Side) -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- DOC # Input (Left) -->
                        <Grid Grid.Column="0" Margin="0,0,7,0">
                            <TextBox
                                x:Name="DOCNumberInput"
                                Width="200"
                                Background="#3C3C3C"
                                Foreground="White"
                                BorderBrush="#555"
                                Padding="10,8"
                                FontSize="14"
                                BorderThickness="1"
                                HorizontalContentAlignment="Center"
                                Text="{Binding DocNumber, UpdateSourceTrigger=PropertyChanged}"
                                TextChanged="DOCNumberInput_TextChanged" />
                            <TextBlock
                                x:Name="DOCNumberPlaceholder"
                                Text="DOC number"
                                Foreground="Gray"
                                FontSize="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False" />
                        </Grid>

                        <!-- Plan Input (Right) -->
                        <Grid Grid.Column="1" Margin="7,0,0,0">
                            <TextBox
                                x:Name="ProjectNumberInput"
                                Width="100"
                                Background="#3C3C3C"
                                Foreground="White"
                                BorderBrush="#555"
                                Padding="10,8"
                                FontSize="14"
                                BorderThickness="1"
                                HorizontalContentAlignment="Center"
                                Text="{Binding ProjectNumber, UpdateSourceTrigger=PropertyChanged}"
                                TextChanged="PlanInput_TextChanged" />
                            <TextBlock
                                x:Name="ProjectNumberPlaceholder"
                                Text="Project number"
                                Foreground="Gray"
                                FontSize="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False" />
                        </Grid>
                    </Grid>

                    <!-- Row 3: Test plan and Prepared by (Side by Side) -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Test plan Input (Left) -->
                        <Grid Grid.Column="0" Margin="0,0,7,0">
                            <TextBox
                                x:Name="TestPlanInput"
                                Width="150"
                                Background="#3C3C3C"
                                Foreground="White"
                                BorderBrush="#555"
                                Padding="10,8"
                                FontSize="14"
                                BorderThickness="1"
                                HorizontalContentAlignment="Center"
                                Text="{Binding TestPlan, UpdateSourceTrigger=PropertyChanged}"
                                TextChanged="TestPlanInput_TextChanged" />
                            <TextBlock
                                x:Name="TestPlanPlaceholder"
                                Text="Test plan"
                                Foreground="Gray"
                                FontSize="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False" />
                        </Grid>

                        <!-- Prepared by Input (Right) -->
                        <Grid Grid.Column="1" Margin="7,0,0,0">
                            <TextBox
                                x:Name="PreparedByInput"
                                Width="150"
                                Background="#3C3C3C"
                                Foreground="White"
                                BorderBrush="#555"
                                Padding="10,8"
                                FontSize="14"
                                BorderThickness="1"
                                HorizontalContentAlignment="Center"
                                Text="{Binding PreparedBy, UpdateSourceTrigger=PropertyChanged}"
                                TextChanged="PreparedByInput_TextChanged" />
                            <TextBlock
                                x:Name="PreparedByPlaceholder"
                                Text="Prepared by"
                                Foreground="Gray"
                                FontSize="14"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False" />
                        </Grid>
                    </Grid>

                    <!-- Row 4: Footer (Centered) -->
                    <Grid Margin="0,0,0,0" HorizontalAlignment="Center">
                        <TextBox
                            x:Name="FooterInput"
                            Width="150"
                            Background="#3C3C3C"
                            Foreground="White"
                            BorderBrush="#555"
                            Padding="10,8"
                            FontSize="14"
                            BorderThickness="1"
                            HorizontalContentAlignment="Center"
                            Text="{Binding Footer, UpdateSourceTrigger=PropertyChanged}"
                            TextChanged="FooterInput_TextChanged" />
                        <TextBlock
                            x:Name="FooterPlaceholder"
                            Text="Footer"
                            Foreground="Gray"
                            FontSize="14"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False" />
                    </Grid>
                    
                </StackPanel>

                <!-- Normalize Button -->
                <Button
                    x:Name="NormalizeButton"
                    Click="NormalizeButton_Click"
                    Style="{StaticResource GreenButton}"
                    MaxWidth="350"
                    Cursor="Hand"
                    Height="40"
                    Margin="0,0,0,0"
                    RenderTransformOrigin="0.5,0.5">
                    <Button.RenderTransform>
                        <ScaleTransform x:Name="NormalizeScale" ScaleX="1" ScaleY="1"/>
                    </Button.RenderTransform>
                    <Button.Effect>
                        <DropShadowEffect x:Name="NormalizeShadow" 
                                          BlurRadius="0" 
                                          ShadowDepth="0" 
                                          Color="#4CAF50" 
                                          Opacity="0"/>
                    </Button.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="Auto" />
                            <ColumnDefinition
                                Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Name="NormalizeIcon"
                            Text="⚙"
                            FontSize="18"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="NormalizeIconRotate" Angle="0"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>

                        <TextBlock
                            Grid.Column="1"
                            Text="Normalize"
                            TextWrapping="Wrap"
                            VerticalAlignment="Center" />
                    </Grid>
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="NormalizeScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1.06" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="NormalizeScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1.06" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="NormalizeShadow"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     To="25" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="NormalizeShadow"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.8" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="NormalizeIconRotate"
                                                     Storyboard.TargetProperty="Angle"
                                                     To="180" Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseInOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="NormalizeScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="NormalizeScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="NormalizeShadow"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     To="0" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="NormalizeShadow"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="NormalizeIconRotate"
                                                     Storyboard.TargetProperty="Angle"
                                                     To="0" Duration="0:0:0.3">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseInOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border
            Grid.Row="2"
            Background="#2D2D30"
            Padding="8"
            CornerRadius="8"
            Margin="0,1,0,0">

            <StackPanel
                HorizontalAlignment="Center">
                <TextBlock
                    x:Name="StatusText"
                    Text="{Binding StatusMessage}"
                    Foreground="LightGray"
                    FontSize="12"
                    HorizontalAlignment="Center" />
                <TextBlock
                    Text="Developed by Bahaa"
                    Foreground="Gray"
                    FontSize="11"
                    FontStyle="Italic"
                    Margin="0,4,0,0"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

    </Grid>
</local:BaseToolWindow>

<local:BaseToolWindow
    x:Class="ste_tool_studio.STDTemplateNormalizer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:ste_tool_studio"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="STD Template Normalizer"
    Width="700"
    Height="710"
    MinWidth="700"
    MinHeight="710"
    AllowDrop="True"
    Background="#1E1E1E"
    DragOver="Window_DragOver"
    Drop="Window_Drop"
    Style="{StaticResource MaterialDesignWindow}"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="20,20,20,5">

        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="1.15" ScaleY="1.15" />
        </Grid.LayoutTransform>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header with Back Button  -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  Back Button  -->
            <Button
                x:Name="BackButton"
                Grid.Column="0"
                MinWidth="40"
                Margin="0,0,15,0"
                Background="#3C3C3C"
                BorderBrush="#555"
                Click="BackButton_Click"
                Cursor="Hand"
                Foreground="White"
                RenderTransformOrigin="0.5,0.5"
                Style="{StaticResource CustomMaterialButton}">
                <Button.RenderTransform>
                    <ScaleTransform x:Name="BackButtonScale" ScaleX="1" ScaleY="1" />
                </Button.RenderTransform>
                <Button.Effect>
                    <DropShadowEffect
                        x:Name="BackButtonShadow"
                        BlurRadius="0"
                        Opacity="0"
                        ShadowDepth="0"
                        Color="#FFFFFF" />
                </Button.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,5,0"
                        VerticalAlignment="Center"
                        FontSize="18"
                        Text="&lt;" />
                </StackPanel>
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource CustomToolTip}">
                        Return to Main Menu
                    </ToolTip>
                </Button.ToolTip>
                <Button.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetName="BackButtonScale"
                                    Storyboard.TargetProperty="ScaleX"
                                    To="1.1"
                                    Duration="0:0:0.2" />
                                <DoubleAnimation
                                    Storyboard.TargetName="BackButtonScale"
                                    Storyboard.TargetProperty="ScaleY"
                                    To="1.1"
                                    Duration="0:0:0.2" />
                                <DoubleAnimation
                                    Storyboard.TargetName="BackButtonShadow"
                                    Storyboard.TargetProperty="BlurRadius"
                                    To="10"
                                    Duration="0:0:0.2" />
                                <DoubleAnimation
                                    Storyboard.TargetName="BackButtonShadow"
                                    Storyboard.TargetProperty="Opacity"
                                    To="0.6"
                                    Duration="0:0:0.2" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetName="BackButtonScale"
                                    Storyboard.TargetProperty="ScaleX"
                                    To="1"
                                    Duration="0:0:0.2" />
                                <DoubleAnimation
                                    Storyboard.TargetName="BackButtonScale"
                                    Storyboard.TargetProperty="ScaleY"
                                    To="1"
                                    Duration="0:0:0.2" />
                                <DoubleAnimation
                                    Storyboard.TargetName="BackButtonShadow"
                                    Storyboard.TargetProperty="BlurRadius"
                                    To="0"
                                    Duration="0:0:0.2" />
                                <DoubleAnimation
                                    Storyboard.TargetName="BackButtonShadow"
                                    Storyboard.TargetProperty="Opacity"
                                    To="0"
                                    Duration="0:0:0.2" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
            </Button>

            <!--  Title  -->
            <TextBlock
                Grid.Column="0"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="26"
                FontWeight="Bold"
                Foreground="White"
                Text="STD Template Normalizer" />

            <!--  Cycle Selector  -->
            <StackPanel
                Grid.Column="2"
                VerticalAlignment="Center"
                Orientation="Horizontal">

                <TextBlock
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    FontSize="15"
                    FontWeight="Bold"
                    Foreground="LightGray"
                    Text="Cycle" />

                <Border
                    Width="80"
                    Height="30"
                    Background="#3C3C3C"
                    BorderBrush="#555"
                    BorderThickness="1"
                    CornerRadius="16">

                    <ComboBox
                        x:Name="CycleDropdown"
                        Width="Auto"
                        Height="Auto"
                        Padding="6,2"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="13"
                        Foreground="White"
                        ItemsSource="{Binding CycleOptions}"
                        SelectedItem="{Binding SelectedCycleId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        ToolTipService.BetweenShowDelay="0"
                        ToolTipService.InitialShowDelay="300">

                        <!--  Tooltip goes here, inside the ComboBox  -->
                        <ComboBox.ToolTip>
                            <ToolTip MaxWidth="400" Style="{StaticResource CustomToolTip}">
                                <TextBlock TextWrapping="Wrap">
                                    Automatically fill Protocol number, Report number, Test Plan, and STx text input fields.
                                </TextBlock>
                            </ToolTip>
                        </ComboBox.ToolTip>

                    </ComboBox>

                </Border>

            </StackPanel>
        </Grid>


        <!--  Main Content  -->
        <Border
            Grid.Row="1"
            Grid.RowSpan="2"
            Margin="0,0,0,59"
            Padding="20"
            Background="#2D2D30"
            CornerRadius="12">

            <StackPanel>

                <!--  File Selector Button  -->
                <Button
                    x:Name="SelectFileButton"
                    Margin="0,0,0,4"
                    Click="SelectFileButton_Click"
                    Cursor="Hand"
                    RenderTransformOrigin="0.5,0.5"
                    Style="{StaticResource PurpleButton}">
                    <Button.RenderTransform>
                        <ScaleTransform x:Name="SelectFileScale" ScaleX="1" ScaleY="1" />
                    </Button.RenderTransform>
                    <Button.Effect>
                        <DropShadowEffect
                            x:Name="SelectFileShadow"
                            BlurRadius="0"
                            Opacity="0"
                            ShadowDepth="0"
                            Color="#9C27B0" />
                    </Button.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Name="SelectFileIcon"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            FontSize="18"
                            RenderTransformOrigin="0.5,0.5"
                            Text="📂">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="SelectFileIconRotate" Angle="0" />
                            </TextBlock.RenderTransform>
                        </TextBlock>

                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Text="Select STD File"
                            TextWrapping="Wrap" />
                    </Grid>
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectFileScale"
                                        Storyboard.TargetProperty="ScaleX"
                                        To="1.05"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectFileScale"
                                        Storyboard.TargetProperty="ScaleY"
                                        To="1.05"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectFileShadow"
                                        Storyboard.TargetProperty="BlurRadius"
                                        To="20"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectFileShadow"
                                        Storyboard.TargetProperty="Opacity"
                                        To="0.7"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectFileIconRotate"
                                        Storyboard.TargetProperty="Angle"
                                        To="15"
                                        Duration="0:0:0.2" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectFileScale"
                                        Storyboard.TargetProperty="ScaleX"
                                        To="1"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectFileScale"
                                        Storyboard.TargetProperty="ScaleY"
                                        To="1"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectFileShadow"
                                        Storyboard.TargetProperty="BlurRadius"
                                        To="0"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectFileShadow"
                                        Storyboard.TargetProperty="Opacity"
                                        To="0"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="SelectFileIconRotate"
                                        Storyboard.TargetProperty="Angle"
                                        To="0"
                                        Duration="0:0:0.2" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <!--  Drag & Drop Hint  -->
                <TextBlock
                    Margin="0,0,0,5"
                    HorizontalAlignment="Center"
                    FontSize="12"
                    FontStyle="Italic"
                    Foreground="LightGray"
                    Text="Or drag and drop an XLSX file here" />

                <!--  Selected File Label  -->
                <TextBlock
                    x:Name="SelectedFileLabel"
                    Margin="0,10,0,15"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    Foreground="LightGray"
                    Text="{Binding SelectedFileName}"
                    TextWrapping="Wrap" />

                <!--  Document Type Card  -->
                <Border
                    Margin="0,0,0,15"
                    Padding="1"
                    HorizontalAlignment="Center"
                    Background="#1E1E1E"
                    BorderBrush="#555"
                    BorderThickness="1"
                    CornerRadius="20">

                    <StackPanel>

                        <!--  Title  -->
                        <TextBlock
                            Margin="6,2,0,5"
                            HorizontalAlignment="Center"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="LightGray"
                            Text="Document Type" />

                        <!--  Toggle Container  -->
                        <Border
                            Padding="3"
                            Background="#111"
                            CornerRadius="16">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>

                                <!--  Protocol  -->
                                <Button
                                    x:Name="ProtocolButton"
                                    Grid.Column="0"
                                    MinWidth="90"
                                    Padding="18,8"
                                    Background="#1E1E1E"
                                    BorderThickness="0"
                                    Click="ProtocolButton_Click"
                                    Content="Protocol"
                                    Cursor="Hand"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="LightGray"
                                    RenderTransformOrigin="0.5,0.5">

                                    <Button.RenderTransform>
                                        <ScaleTransform x:Name="ProtocolScale" ScaleX="1" ScaleY="1" />
                                    </Button.RenderTransform>
                                    <Button.Effect>
                                        <DropShadowEffect
                                            x:Name="ProtocolShadow"
                                            BlurRadius="0"
                                            Opacity="0"
                                            ShadowDepth="0"
                                            Color="#4CAF50" />
                                    </Button.Effect>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="16">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Triggers>
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ProtocolScale"
                                                        Storyboard.TargetProperty="ScaleX"
                                                        To="1.08"
                                                        Duration="0:0:0.2" />
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ProtocolScale"
                                                        Storyboard.TargetProperty="ScaleY"
                                                        To="1.08"
                                                        Duration="0:0:0.2" />
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ProtocolShadow"
                                                        Storyboard.TargetProperty="BlurRadius"
                                                        To="12"
                                                        Duration="0:0:0.2" />
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ProtocolShadow"
                                                        Storyboard.TargetProperty="Opacity"
                                                        To="0.5"
                                                        Duration="0:0:0.2" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ProtocolScale"
                                                        Storyboard.TargetProperty="ScaleX"
                                                        To="1"
                                                        Duration="0:0:0.2" />
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ProtocolScale"
                                                        Storyboard.TargetProperty="ScaleY"
                                                        To="1"
                                                        Duration="0:0:0.2" />
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ProtocolShadow"
                                                        Storyboard.TargetProperty="BlurRadius"
                                                        To="0"
                                                        Duration="0:0:0.2" />
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ProtocolShadow"
                                                        Storyboard.TargetProperty="Opacity"
                                                        To="0"
                                                        Duration="0:0:0.2" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Button.Triggers>

                                </Button>

                                <!--  Report  -->
                                <Button
                                    x:Name="ReportButton"
                                    Grid.Column="1"
                                    MinWidth="90"
                                    Padding="18,8"
                                    Background="#1E1E1E"
                                    BorderThickness="0"
                                    Click="ReportButton_Click"
                                    Content="Report"
                                    Cursor="Hand"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="LightGray"
                                    RenderTransformOrigin="0.5,0.5">

                                    <Button.RenderTransform>
                                        <ScaleTransform x:Name="ReportScale" ScaleX="1" ScaleY="1" />
                                    </Button.RenderTransform>
                                    <Button.Effect>
                                        <DropShadowEffect
                                            x:Name="ReportShadow"
                                            BlurRadius="0"
                                            Opacity="0"
                                            ShadowDepth="0"
                                            Color="#4CAF50" />
                                    </Button.Effect>
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="16">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Triggers>
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ReportScale"
                                                        Storyboard.TargetProperty="ScaleX"
                                                        To="1.08"
                                                        Duration="0:0:0.2" />
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ReportScale"
                                                        Storyboard.TargetProperty="ScaleY"
                                                        To="1.08"
                                                        Duration="0:0:0.2" />
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ReportShadow"
                                                        Storyboard.TargetProperty="BlurRadius"
                                                        To="12"
                                                        Duration="0:0:0.2" />
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ReportShadow"
                                                        Storyboard.TargetProperty="Opacity"
                                                        To="0.5"
                                                        Duration="0:0:0.2" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ReportScale"
                                                        Storyboard.TargetProperty="ScaleX"
                                                        To="1"
                                                        Duration="0:0:0.2" />
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ReportScale"
                                                        Storyboard.TargetProperty="ScaleY"
                                                        To="1"
                                                        Duration="0:0:0.2" />
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ReportShadow"
                                                        Storyboard.TargetProperty="BlurRadius"
                                                        To="0"
                                                        Duration="0:0:0.2" />
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ReportShadow"
                                                        Storyboard.TargetProperty="Opacity"
                                                        To="0"
                                                        Duration="0:0:0.2" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Button.Triggers>

                                </Button>

                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>

                <!--  Input Fields  -->
                <StackPanel Margin="0,0,0,15" HorizontalAlignment="Center">

                    <!--  Row 1: STD Name (Full Width)  -->
                    <Grid Margin="0,0,0,10" HorizontalAlignment="Center">
                        <TextBox
                            x:Name="STDNameInput"
                            Width="314"
                            Padding="10,8"
                            HorizontalContentAlignment="Center"
                            Background="#3C3C3C"
                            BorderBrush="#555"
                            BorderThickness="1"
                            FontSize="14"
                            Foreground="White"
                            Text="{Binding StdName, UpdateSourceTrigger=PropertyChanged}"
                            TextChanged="STDNameInput_TextChanged" />
                        <TextBlock
                            x:Name="STDNamePlaceholder"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="Gray"
                            IsHitTestVisible="False"
                            Text="STD Name" />
                    </Grid>

                    <!--  Row 2: Protocol number and Report number (Report mode only)  -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Protocol number Input (Left)  -->
                        <Grid Grid.Column="0" Margin="0,0,7,0">
                            <TextBox
                                x:Name="ProtocolNumberInput"
                                Width="200"
                                Padding="10,8"
                                HorizontalContentAlignment="Center"
                                Background="#3C3C3C"
                                BorderBrush="#555"
                                BorderThickness="1"
                                FontSize="14"
                                Foreground="White"
                                Text="{Binding ProtocolNumber, UpdateSourceTrigger=PropertyChanged}"
                                TextChanged="ProtocolNumberInput_TextChanged" />
                            <TextBlock
                                x:Name="ProtocolNumberPlaceholder"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="Gray"
                                IsHitTestVisible="False"
                                Text="Protocol number" />
                        </Grid>

                        <!--  Report number Input (Right, only visible in Report mode)  -->
                        <Grid Grid.Column="1" Margin="7,0,0,0">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsReportMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <TextBox
                                x:Name="ReportNumberInput"
                                Width="100"
                                Padding="10,8"
                                HorizontalContentAlignment="Center"
                                Background="#3C3C3C"
                                BorderBrush="#555"
                                BorderThickness="1"
                                FontSize="14"
                                Foreground="White"
                                Text="{Binding ReportNumber, UpdateSourceTrigger=PropertyChanged}"
                                TextChanged="ReportNumberInput_TextChanged" />
                            <TextBlock
                                x:Name="ReportNumberPlaceholder"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="Gray"
                                IsHitTestVisible="False"
                                Text="Report number" />
                        </Grid>
                    </Grid>

                    <!--  Row 3: Test plan and STx number (Side by Side)  -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Test plan Input (Left)  -->
                        <Grid Grid.Column="0" Margin="0,0,7,0">
                            <TextBox
                                x:Name="TestPlanInput"
                                Width="150"
                                Padding="10,8"
                                HorizontalContentAlignment="Center"
                                Background="#3C3C3C"
                                BorderBrush="#555"
                                BorderThickness="1"
                                FontSize="14"
                                Foreground="White"
                                Text="{Binding TestPlan, UpdateSourceTrigger=PropertyChanged}"
                                TextChanged="TestPlanInput_TextChanged" />
                            <TextBlock
                                x:Name="TestPlanPlaceholder"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="Gray"
                                IsHitTestVisible="False"
                                Text="Test plan" />
                        </Grid>

                        <!--  STx number Input (Right)  -->
                        <Grid Grid.Column="1" Margin="7,0,0,0">
                            <TextBox
                                x:Name="STxInput"
                                Width="150"
                                Padding="10,8"
                                HorizontalContentAlignment="Center"
                                Background="#3C3C3C"
                                BorderBrush="#555"
                                BorderThickness="1"
                                FontSize="14"
                                Foreground="White"
                                Text="{Binding STxNumber, UpdateSourceTrigger=PropertyChanged}"
                                TextChanged="STxInput_TextChanged" />
                            <TextBlock
                                x:Name="STxPlaceholder"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="Gray"
                                IsHitTestVisible="False"
                                Text="STx number" />
                        </Grid>
                    </Grid>

                    <!--  Row 4: Prepared by (Centered)  -->
                    <Grid Margin="0,0,0,0" HorizontalAlignment="Center">
                        <TextBox
                            x:Name="PreparedByInput"
                            Width="150"
                            Padding="10,8"
                            HorizontalContentAlignment="Center"
                            Background="#3C3C3C"
                            BorderBrush="#555"
                            BorderThickness="1"
                            FontSize="14"
                            Foreground="White"
                            Text="{Binding PreparedBy, UpdateSourceTrigger=PropertyChanged}"
                            TextChanged="PreparedByInput_TextChanged" />
                        <TextBlock
                            x:Name="PreparedByPlaceholder"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="Gray"
                            IsHitTestVisible="False"
                            Text="Prepared by" />
                    </Grid>

                </StackPanel>

                <!--  Normalize Button  -->
                <Button
                    x:Name="NormalizeButton"
                    Height="40"
                    MaxWidth="350"
                    Margin="0,0,0,0"
                    Click="NormalizeButton_Click"
                    Cursor="Hand"
                    RenderTransformOrigin="0.5,0.5"
                    Style="{StaticResource GreenButton}">
                    <Button.RenderTransform>
                        <ScaleTransform x:Name="NormalizeScale" ScaleX="1" ScaleY="1" />
                    </Button.RenderTransform>
                    <Button.Effect>
                        <DropShadowEffect
                            x:Name="NormalizeShadow"
                            BlurRadius="0"
                            Opacity="0"
                            ShadowDepth="0"
                            Color="#4CAF50" />
                    </Button.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Name="NormalizeIcon"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            FontSize="18"
                            RenderTransformOrigin="0.5,0.5"
                            Text="⚙">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="NormalizeIconRotate" Angle="0" />
                            </TextBlock.RenderTransform>
                        </TextBlock>

                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Text="Normalize"
                            TextWrapping="Wrap" />
                    </Grid>
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetName="NormalizeScale"
                                        Storyboard.TargetProperty="ScaleX"
                                        To="1.06"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="NormalizeScale"
                                        Storyboard.TargetProperty="ScaleY"
                                        To="1.06"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="NormalizeShadow"
                                        Storyboard.TargetProperty="BlurRadius"
                                        To="25"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="NormalizeShadow"
                                        Storyboard.TargetProperty="Opacity"
                                        To="0.8"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="NormalizeIconRotate"
                                        Storyboard.TargetProperty="Angle"
                                        To="180"
                                        Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseInOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetName="NormalizeScale"
                                        Storyboard.TargetProperty="ScaleX"
                                        To="1"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="NormalizeScale"
                                        Storyboard.TargetProperty="ScaleY"
                                        To="1"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="NormalizeShadow"
                                        Storyboard.TargetProperty="BlurRadius"
                                        To="0"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="NormalizeShadow"
                                        Storyboard.TargetProperty="Opacity"
                                        To="0"
                                        Duration="0:0:0.2" />
                                    <DoubleAnimation
                                        Storyboard.TargetName="NormalizeIconRotate"
                                        Storyboard.TargetProperty="Angle"
                                        To="0"
                                        Duration="0:0:0.3">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseInOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

            </StackPanel>
        </Border>

        <!--  Status Bar  -->
        <Border
            Grid.Row="2"
            Margin="0,1,0,0"
            Padding="8"
            Background="#2D2D30"
            CornerRadius="8">

            <StackPanel HorizontalAlignment="Center">
                <TextBlock
                    x:Name="StatusText"
                    HorizontalAlignment="Center"
                    FontSize="12"
                    Foreground="LightGray"
                    Text="{Binding StatusMessage}" />
                <TextBlock
                    Margin="0,4,0,0"
                    HorizontalAlignment="Center"
                    FontSize="11"
                    FontStyle="Italic"
                    Foreground="Gray"
                    Text="Developed by Bahaa" />
            </StackPanel>
        </Border>

    </Grid>
</local:BaseToolWindow>
